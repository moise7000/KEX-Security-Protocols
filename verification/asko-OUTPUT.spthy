guarded formula characterizing all counter-examples:
"∃ A B t #i.
  (Commit_B( A, B, <'init', t> ) @ #i)
 ∧
  (∀ #j. (Running_A( A, B, <'init', t> ) @ #j) ⇒ ¬(#j < #i)) ∧
  (∀ #r. (Reveal( A ) @ #r) ⇒ ⊥) ∧
  (∀ #r. (Reveal( B ) @ #r) ⇒ ⊥)"
*/
simplify
solve( St_B_1( $A, $B, t, tau, lambda ) ▶₀ #i )
  case B_1_receive_from_server
  solve( !KU( senc(<$A, tau, lambda, t>, ~kBS) ) @ #vk.1 )
    case S_forward_to_B
    solve( !KU( senc(<$B, tau, lambda, t>, ~kAS) ) @ #vk.2 )
      case A_2_send_to_server
      by contradiction /* from formulas */
    next
      case c_senc
      solve( !KU( ~kAS ) @ #vk.4 )
        case Reveal_Key_AS
        by contradiction /* from formulas */
      qed
    qed
  next
    case c_senc
    solve( !KU( ~kBS ) @ #vk.3 )
      case Reveal_Key_BS
      by contradiction /* from formulas */
    qed
  qed
qed

