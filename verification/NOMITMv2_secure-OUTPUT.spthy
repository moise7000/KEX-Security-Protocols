  simplify
  solve( (last(#i))  ∥
         (∃ #j. (!KU( x ) @ #j) ∧ (¬(last(#j))) ∧ (#j < #i))  ∥
         (∃ #j.
           (AUTO_OUT_TERM_1_0_0_1_0__Init_2( aenc(<$B, x, ~na>, pk(~ltkA)) ) @ #j)
          ∧
           (¬(last(#j))) ∧ (#j < #i)) )
    case case_1
    solve( St_A_1( $A, $B, ~na ) ▶₀ #i )
      case Init_1
      solve( !Ltk( $A, ~ltkA ) ▶₂ #i )
        case Register_pk
        solve( !Pk( $B, pkB ) ▶₃ #i )
          case Register_pk
          solve( !KU( aenc(<$B, x, ~na>, pk(~ltkA)) ) @ #vk )
            case Init_2
            solve( (∃ #j. (!KU( nb ) @ #j) ∧ (¬(last(#j))) ∧ (#j < #vr.3))  ∥
                   (∃ #j.
                     (AUTO_OUT_TERM_1_0_0_1_0__Init_2( aenc(<$B.1, nb, ~na.1>, pk(~ltkA.1))
                      ) @ #j)
                    ∧
                     (¬(last(#j))) ∧ (#j < #vr.3)) )
