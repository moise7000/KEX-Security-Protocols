"∃ A B n k #i.
  (Commit_I( A, B, n, k ) @ #i)
 ∧
  ((∀ #j. (Generate( k ) @ #j) ⇒ ⊥) ∨
   (∃ A2 B2 n2 #i2. (Commit_I( A2, B2, n2, k ) @ #i2) ∧ ¬(#i2 = #i)))"
*/
