lemma agreement_B_A:
  all-traces
  "∀ A B t #i.
    (Commit_B( A, B, <'init', t> ) @ #i) ⇒
    (((∃ #j. (Running_A( A, B, <'init', t> ) @ #j) ∧ (#j < #i)) ∨
      (∃ #r. Reveal( A ) @ #r)) ∨
